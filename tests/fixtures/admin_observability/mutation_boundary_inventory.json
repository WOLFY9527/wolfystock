  "mutation_surfaces": [
    {
      "surface": "admin_logs_cleanup",
      "route": "POST /api/v1/admin/logs/cleanup",
      "auth_dependency_label": "admin_capability",
      "capability_label": "ops:logs:write",
      "dangerous": true,
      "danger_zone": "destructive_retention_cleanup",
      "bounded_response_only": true
    },
    {
      "surface": "admin_user_security",
      "route": "POST /api/v1/admin/users/:userId/disable",
      "auth_dependency_label": "admin_capability",
      "capability_label": "users:security:write",
      "dangerous": true,
      "danger_zone": "user_access_control",
      "bounded_response_only": true
    },
    {
      "surface": "admin_notifications_write",
      "route": "POST|PATCH|DELETE /api/v1/admin/notification-channels",
      "auth_dependency_label": "admin_capability",
      "capability_label": "ops:notifications:write",
      "dangerous": true,
      "danger_zone": "notification_delivery_controls",
      "bounded_response_only": true
    },
    {
      "surface": "system_provider_tests",
      "route": "POST /api/v1/system/config/data-source/test",
      "auth_dependency_label": "admin_capability",
      "capability_label": "ops:providers:write",
      "dangerous": true,
      "danger_zone": "provider_runtime_side_effects",
      "bounded_response_only": true
    }
  ],
  "ownership_boundary": {
    "admin_observability_role": "consumes_domain_contracts_only",
    "consumes": [
      "execution_log_diagnostics",
      "cost_ledger_rollups",
      "provider_runtime_health",
      "user_activity_read_model",
      "portfolio_read_projection"
    ],
    "must_not_own": [
      "scanner_ranking",
      "backtest_calculations",
      "portfolio_accounting",
      "provider_fallback_policy",
      "ai_routing_policy",
      "auth_enforcement"
    ],
    "transitional_gaps": []
  },
  "sanitization_rules": [
    "no_raw_provider_details",
    "no_body_dump",
    "no_header_dump",
    "no_auth_tokens",
    "no_pass_hashes",
    "no_exception_dump",
    "bounded_diagnostic_details_only"
  ],
  "raw_details_policy": {
    "allowed": "bounded_diagnostic_metadata_only",
    "forbidden": [
      "payload_content",
      "credential_values",
      "secret_material",
      "full_exception_dump"
    ]
  }
}
